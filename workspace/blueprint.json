{
  "phase": 2,
  "status": "pending_approval",
  "title": "Footer Component Blueprint - Client-First V1",
  "target_page": "Global",
  "rationale": "Thiết kế Footer chuẩn Client-First với cấu trúc 6 lớp, phân tách 2 vùng màu (Dark/Light) và hệ thống Class Finsweet chuyên dụng. Toàn bộ đơn vị đã được chuyển đổi sang REM.",
  "structure": {
    "component": "footer_component",
    "tag": "footer",
    "nesting": "page-wrapper > footer_component (sibling to navbar and main-wrapper)",
    "layers": [
      {
        "layer_name": "footer_top-section",
        "description": "Phần trên màu xanh đậm chứa thông tin liên hệ và giới thiệu.",
        "styles": {
          "background-color": "#1c1e53",
          "color": "#ffffff"
        },
        "children": [
          {
            "class": "padding-global",
            "children": [
              {
                "class": "container-large",
                "children": [
                  {
                    "class": "padding-section-large",
                    "styles": {
                      "padding-top": "6rem",
                      "padding-bottom": "0rem"
                    },
                    "children": [
                      {
                        "class": "footer_top-grid",
                        "layout": "Grid (2 columns, gap 4rem, align-items: start)",
                        "children": [
                          {
                            "class": "footer_left-column",
                            "styles": {
                              "display": "flex",
                              "flex-direction": "column",
                              "padding-bottom": "6rem"
                            },
                            "children": [
                              "footer_logo-link",
                              "footer_description-left (text-size-medium, color: #ffffff, opacity 0.8)",
                              {
                                "class": "footer_contact-box",
                                "styles": {
                                  "background-color": "#fcd980",
                                  "margin-top": "auto",
                                  "padding": "2.5rem 3rem"
                                },
                                "children": [
                                  {
                                    "class": "footer_contact-grid",
                                    "layout": "Grid (2 columns, gap 2rem)",
                                    "children": [
                                      "footer_contact-item (Email)",
                                      "footer_contact-item (Phone)"
                                    ]
                                  }
                                ]
                              }
                            ]
                          },
                          {
                            "class": "footer_right-column",
                            "styles": {
                              "display": "flex",
                              "flex-direction": "column",
                              "padding-bottom": "6rem"
                            },
                            "children": [
                              "footer_heading (heading-style-h2, Lets Talk!)",
                              "footer_description-right (text-size-medium, color: #f4f6fc, opacity 0.8)",
                              "footer_social-list"
                            ]
                          }
                        ]
                      }
                    ]
                  }
                ]
              }
            ]
          }
        ]
      },
      {
        "layer_name": "footer_bottom-section",
        "description": "Phần dưới màu trắng chứa Copyright và Navigation Links.",
        "styles": {
          "background-color": "#ffffff",
          "color": "#282938"
        },
        "children": [
          {
            "class": "padding-global",
            "children": [
              {
                "class": "container-large",
                "children": [
                  {
                    "class": "padding-section-small",
                    "styles": {
                      "padding-top": "2rem",
                      "padding-bottom": "2rem"
                    },
                    "children": [
                      {
                        "class": "footer_bottom-grid",
                        "layout": "Flex (justify-between, align-center)",
                        "children": [
                          "footer_copyright",
                          "footer_nav-list"
                        ]
                      }
                    ]
                  }
                ]
              }
            ]
          }
        ]
      }
    ]
  },
  "class_mapping": {
    "logo": "footer_logo-link",
    "contact_box": "footer_contact-box",
    "contact_item": "footer_contact-item",
    "contact_label": "footer_contact-label",
    "contact_value": "footer_contact-value",
    "social_list": "footer_social-list",
    "social_link": "footer_social-link",
    "nav_list": "footer_nav-list",
    "nav_link": "footer_nav-link",
    "copyright": "footer_copyright"
  },
  "typography_rem": {
    "h2": "3rem (48px)",
    "p_regular": "1rem (16px)",
    "contact_label": "1.125rem (18px)",
    "line_height_h2": "4rem (64px)",
    "line_height_p": "1.75rem (28px)"
  },
  "qa_checklist": [
    "Cấu trúc 6 lớp chuẩn Client-First (Section > Global > Container > Section Padding > Content)",
    "Footer nằm trong page-wrapper, ngoài main-wrapper",
    "Đặt tên class chuẩn Finsweet (Dấu _ cho Custom, Dấu - cho Utility)",
    "100% đơn vị sử dụng REM",
    "Phân tách rõ rệt footer_top-section và footer_bottom-section"
  ]
}