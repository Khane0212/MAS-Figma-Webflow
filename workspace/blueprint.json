{
  "phase": 1,
  "title": "Contact Us Page Implementation",
  "status": "pending",
  "target_page": "Contact Us",
  "rationale": "Following Client-First v2 standard. Using custom classes for component structure and utility classes for spacing/typography. Navbar and Footer are handled as global components. Grid layout used for the form to ensure responsiveness.",
  "structure": [
    {
      "component": "Navbar",
      "type": "Global",
      "structure_tree": {
        "tag": "div",
        "class": "nav_component",
        "children": [
          {
            "tag": "div",
            "class": "padding-global",
            "children": [
              {
                "tag": "div",
                "class": "container-large",
                "children": [
                  {
                    "tag": "div",
                    "class": "nav_wrapper",
                    "children": [
                      { "tag": "img", "class": "nav_logo", "alt": "Finsweet Logo" },
                      {
                        "tag": "nav",
                        "class": "nav_menu",
                        "children": [
                          { "tag": "a", "class": "nav_link", "text": "Home" },
                          { "tag": "a", "class": "nav_link", "text": "About us" },
                          { "tag": "a", "class": "nav_link", "text": "Features" },
                          { "tag": "a", "class": "nav_link", "text": "Pricing" },
                          { "tag": "a", "class": "nav_link", "text": "FAQ" },
                          { "tag": "a", "class": "nav_link", "text": "Blog" },
                          { "tag": "a", "class": "button is-nav", "text": "Contact us" }
                        ]
                      }
                    ]
                  }
                ]
              }
            ]
          }
        ]
      },
      "styles": {
        "nav_component": { "background-color": "var(--color-brand-navy)", "height": "5.75rem", "display": "flex", "align-items": "center" },
        "nav_wrapper": { "display": "flex", "justify-content": "space-between", "align-items": "center", "width": "100%" },
        "nav_menu": { "display": "flex", "align-items": "center", "column-gap": "2rem" },
        "nav_link": { "color": "var(--color-neutral-muted)", "text-decoration": "none", "font-size": "1rem", "font-weight": "500" },
        "button.is-nav": { "padding": "1rem 2rem", "border": "2px solid rgba(244, 246, 252, 0.2)", "border-radius": "2.5rem", "color": "white" }
      }
    },
    {
      "component": "Contact Header",
      "type": "Section",
      "structure_tree": {
        "tag": "section",
        "class": "section_contact-header",
        "children": [
          {
            "tag": "div",
            "class": "padding-global",
            "children": [
              {
                "tag": "div",
                "class": "container-large",
                "children": [
                  {
                    "tag": "div",
                    "class": "padding-section-large",
                    "children": [
                      {
                        "tag": "div",
                        "class": "max-width-large align-center",
                        "children": [
                          { "tag": "h1", "class": "heading-style-h2", "text": "Contact Us" },
                          { "tag": "div", "class": "margin-top margin-small" },
                          { "tag": "p", "class": "text-size-medium text-align-center opacity-70", "text": "Lorem ipsum dolor sit amet, consectetur adipiscing elit, sed do eiusmod tempor incididunt ut labore." }
                        ]
                      }
                    ]
                  }
                ]
              }
            ]
          }
        ]
      }
    },
    {
      "component": "Contact Form",
      "type": "Section",
      "structure_tree": {
        "tag": "section",
        "class": "section_contact-form",
        "children": [
          {
            "tag": "div",
            "class": "padding-global",
            "children": [
              {
                "tag": "div",
                "class": "container-large",
                "children": [
                  {
                    "tag": "div",
                    "class": "contact-form_component",
                    "children": [
                      {
                        "tag": "form",
                        "class": "contact-form_form",
                        "children": [
                          {
                            "tag": "div",
                            "class": "contact-form_grid",
                            "children": [
                              {
                                "tag": "div",
                                "class": "form_field-wrapper",
                                "children": [
                                  { "tag": "label", "text": "Name" },
                                  { "tag": "input", "placeholder": "Enter your name", "class": "form_input" }
                                ]
                              },
                              {
                                "tag": "div",
                                "class": "form_field-wrapper",
                                "children": [
                                  { "tag": "label", "text": "Email" },
                                  { "tag": "input", "placeholder": "Enter your Email", "class": "form_input" }
                                ]
                              },
                              {
                                "tag": "div",
                                "class": "form_field-wrapper",
                                "children": [
                                  { "tag": "label", "text": "Subject" },
                                  { "tag": "input", "placeholder": "Provide context", "class": "form_input" }
                                ]
                              },
                              {
                                "tag": "div",
                                "class": "form_field-wrapper",
                                "children": [
                                  { "tag": "label", "text": "Subject" },
                                  { "tag": "select", "class": "form_input" }
                                ]
                              },
                              {
                                "tag": "div",
                                "class": "form_field-wrapper is-full-width",
                                "children": [
                                  { "tag": "label", "text": "Message" },
                                  { "tag": "textarea", "placeholder": "Write your question here", "class": "form_input is-text-area" }
                                ]
                              }
                            ]
                          },
                          { "tag": "input", "type": "submit", "value": "Send Message", "class": "button is-form" }
                        ]
                      }
                    ]
                  }
                ]
              }
            ]
          }
        ]
      },
      "styles": {
        "contact-form_component": { "background-color": "var(--color-neutral-light)", "padding": "5rem", "border-radius": "0.75rem" },
        "contact-form_grid": { "display": "grid", "grid-template-columns": "1fr 1fr", "gap": "2rem" },
        "form_field-wrapper.is-full-width": { "grid-column": "1 / 3" },
        "form_input": { "width": "100%", "padding": "1.125rem 2rem", "border": "1px solid rgba(0,0,0,0.12)", "border-radius": "0.5rem", "background-color": "transparent" },
        "form_input.is-text-area": { "height": "8.625rem" },
        "button.is-form": { "background-color": "var(--color-neutral-dark)", "color": "white", "padding": "1rem 3.25rem", "border-radius": "2.5rem", "margin-top": "2.5rem" }
      }
    }
  ],
  "qa_checklist": [
    "Navbar background: #1c1e53 (var)",
    "Form background: #f4f6fc (var)",
    "All spacing in rem",
    "6-layer hierarchy present in all sections",
    "Button border radius 41px -> 2.56rem"
  ]
}
