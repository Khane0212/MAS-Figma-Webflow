        },
        "aspect-ratio-portrait": {
            "aspectRatio": "2/3",
            "objectFit": "cover"
        },
        "aspect-ratio-square": {
            "aspectRatio": "1/1",
            "objectFit": "cover"
        },
        "aspect-ratio-widescreen": {
            "aspectRatio": "16/9",
